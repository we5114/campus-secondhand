# 校园二手交易智能分析与推荐平台 - 后端配置文件
# 环境变量配置示例

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=campus_trade

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch配置
ES_HOST=localhost
ES_PORT=9200

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 应用配置
APP_NAME=校园二手交易平台
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# 大模型配置
LLM_API_KEY=your-api-key
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=qwen-7b-chat

# 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BEHAVIOR=user_behavior

# Spark配置
SPARK_MASTER=local[*]
SPARK_APP_NAME=campus-trade-spark
